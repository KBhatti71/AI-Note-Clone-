# NeuroApp Backend — Environment Variables
# Copy to .env and fill in your values

# OpenAI (for flashcard generation and action item extraction)
OPENAI_API_KEY=sk-...

# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower
WHISPER_MODEL=base

# PostgreSQL (for production; in-memory store used for MVP)
DATABASE_URL=postgresql://postgres:password@localhost:5432/neuroapp

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
